# SSH Commander does not require any environment variables to run.
# The server listens on http://localhost:3000 by default.
#
# Optional:
# HOST=0.0.0.0       # bind address (default 127.0.0.1 / loopback). Set to 0.0.0.0
#                    # to expose on the network — there is NO built-in auth, so only
#                    # do this behind your own auth on a trusted network.
# DISABLE_HMR=true   # turn off Vite hot-reload / file watching during dev
